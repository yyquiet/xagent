FROM node:22-slim

LABEL maintainer="xagent"
LABEL description="Full sandbox image with all tools"

######################## python 3.11 install (apt)

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        netbase \
        tzdata \
        python3.11 \
        python3-pip \
        python3-venv \
    && ln -sf /usr/bin/python3.11 /usr/local/bin/python \
    && ln -sf /usr/bin/python3.11 /usr/local/bin/python3 \
    && ln -sf /usr/bin/pip3 /usr/local/bin/pip \
    && rm -rf /var/lib/apt/lists/* \
    && python --version && pip --version

######################## tools dependencies

COPY docker/sandbox-requirements.txt /tmp/sandbox-requirements.txt

# Install tools dependencies
RUN pip install --no-cache-dir --break-system-packages -r /tmp/sandbox-requirements.txt \
    && rm /tmp/sandbox-requirements.txt

# Allow pip install without --break-system-packages globally
RUN printf '[global]\nbreak-system-packages = true\n' > /etc/pip.conf

########################

# Create sandbox user
RUN groupadd --gid 1010 sandbox \
    && useradd --uid 1100 --gid sandbox --shell /bin/bash --create-home sandbox

USER sandbox
WORKDIR /home/sandbox

CMD ["bash"]
